// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  avatarUrl  String?
  bio        String?
  statusText String?
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  conversationsAsUser1 Conversation[] @relation("User1Conversations")
  conversationsAsUser2 Conversation[] @relation("User2Conversations")
  sentMessages         Message[]      @relation("SentMessages")
  uploadedAttachments  Attachment[]
  reactions            Reaction[]
}

model Conversation {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user1LastReadAt DateTime @default(now())
  user2LastReadAt DateTime @default(now())

  // Participants (one-to-one chat)
  user1Id String
  user2Id String
  user1   User   @relation("User1Conversations", fields: [user1Id], references: [id])
  user2   User   @relation("User2Conversations", fields: [user2Id], references: [id])

  // Messages
  messages Message[]

  @@unique([user1Id, user2Id])
  @@index([updatedAt])
}

model Message {
  id               String    @id @default(uuid())
  clientTempId     String?
  content          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt
  editedAt         DateTime?
  deletedAt        DateTime?
  deliveredAt      DateTime?
  readAt           DateTime?
  replyToMessageId String?

  // Relations
  senderId         String
  sender           User         @relation("SentMessages", fields: [senderId], references: [id])
  conversationId   String
  conversation     Conversation @relation(fields: [conversationId], references: [id])
  replyToMessage   Message?     @relation("MessageReplies", fields: [replyToMessageId], references: [id])
  replies          Message[]    @relation("MessageReplies")
  attachments      Attachment[]
  reactions        Reaction[]

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
  @@index([conversationId, deliveredAt])
  @@unique([senderId, clientTempId])
}

model Attachment {
  id           String   @id @default(uuid())
  originalName String
  storedName   String
  mimeType     String
  size         Int
  kind         String
  url          String
  createdAt    DateTime @default(now())

  uploadedById String
  uploadedBy   User    @relation(fields: [uploadedById], references: [id])
  messageId    String?
  message      Message? @relation(fields: [messageId], references: [id])

  @@index([messageId])
  @@index([uploadedById])
}

model Reaction {
  id        String   @id @default(uuid())
  emoji     String
  createdAt DateTime @default(now())

  messageId String
  message   Message @relation(fields: [messageId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}
